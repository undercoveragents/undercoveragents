.detail-grid
  .detail-item
    .detail-label Adapter
    .detail-value= connector.adapter_type.titleize
  .detail-item
    .detail-label Host
    .detail-value= connector.display_host
  .detail-item
    .detail-label Schema
    .detail-value= connector.schema_name
  .detail-item
    .detail-label SSL
    .detail-value= connector.ssl_enabled? ? "Enabled" : "Disabled"
  .detail-item
    .detail-label Pool Size
    .detail-value= connector.pool_size
  .detail-item
    .detail-label Timeout
    .detail-value #{connector.timeout}ms
  .detail-item
    .detail-label Read Only
    .detail-value= connector.read_only? ? "Yes" : "No"
  .detail-item
    .detail-label Max Results
    .detail-value= number_with_delimiter(connector.max_results)

.mt-4.pt-4.border-t.border-border-default{ data: { controller: "sql-database-connector-test", sql_database_connector_test_endpoint_value: admin_test_connection_sql_database_connectors_path, sql_database_connector_test_payload_value: { sql_database: connector.connection_test_params }.to_json } }
  .flex.items-center.gap-3
    %button.btn.btn-secondary{ type: "button", data: { action: "click->sql-database-connector-test#test", sql_database_connector_test_target: "testBtn" } }
      %i.fa-solid.fa-plug-circle-check.mr-1
      Test Connection
  .test-connection-result.mt-3{ data: { sql_database_connector_test_target: "testResult" } }
