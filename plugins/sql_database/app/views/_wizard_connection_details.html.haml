- fields_mode = connection_mode == "fields"
- show_database_select = fields_mode && connector.adapter_type == "postgresql"
- database_placeholder = connector.adapter_type == "sqlite" ? "/path/to/database.sqlite3" : "my_database"
- database_hint = nil
- if show_database_select
  - database_hint = "Load the current catalog from the configured server, then pick the database from the dropdown."
- elsif connector.adapter_type == "mysql"
  - database_hint = "Enter the database name directly for MySQL connections."
- else
  - database_hint = "SQLite uses a manual database identifier or local file path."
- database_status_message = nil
- if show_database_select && selected_database.present?
  - database_status_message = "Current selection: #{selected_database}. Reload the catalog if the server changed."
- elsif show_database_select
  - database_status_message = "Load the server catalog to populate the database dropdown."
- elsif connector.adapter_type == "mysql"
  - database_status_message = "MySQL uses manual database name entry."
- else
  - database_status_message = "This adapter uses a manual database identifier or local file path."

.ui-wizard__panel#sql-connector-step-connect
  = render "shared/wizard/section_head",
           step:,
           copy: "Choose how this connector should authenticate, then load the server catalog so the database name comes from the live instance."
  .ui-wizard__mode-grid
    %label.ui-wizard__mode-option
      = radio_button_tag :sql_database_connection_mode,
                         "fields",
                         fields_mode,
                         class: "ui-wizard__mode-input",
                         data: { action: "change->sql-database-connector-form#syncConnectionMode" }
      .ui-wizard__mode-card
        %span.ui-wizard__mode-icon
          %i.fa-solid.fa-sliders
        %strong Use connection fields
        %p Keep host, credentials, and the database picker separate.
    %label.ui-wizard__mode-option
      = radio_button_tag :sql_database_connection_mode,
                         "connection_string",
                         !fields_mode,
                         class: "ui-wizard__mode-input",
                         data: { action: "change->sql-database-connector-form#syncConnectionMode" }
      .ui-wizard__mode-card
        %span.ui-wizard__mode-icon
          %i.fa-solid.fa-link
        %strong Use a connection string
        %p Paste a full URI when the environment already provides one.

  .ui-wizard__source-body.mt-4{ class: ("hidden" unless fields_mode), data: { sql_database_connector_form_target: "fieldsModeBody" } }
    .form-grid
      .form-group{ data: { controller: "choices", choices_search_value: "false" } }
        = f.label "sql_database[adapter_type]", "Database Type", class: "form-label"
        = f.select "sql_database[adapter_type]",
                   adapter_options,
                   {},
                   class: "form-input form-select",
                   data: { choices_target: "select", action: "change->sql-database-connector-form#onAdapterChange", sql_database_connector_form_target: "adapterSelect" }

      .form-group
        = f.label "sql_database[host]", class: "form-label" do
          Host
          %span.text-danger-500.ml-0.5 *
        = f.text_field "sql_database[host]",
                       value: connector.host,
                       class: "form-input",
                       placeholder: "localhost",
                       required: true,
                       data: { sql_database_connector_form_target: "hostInput" }
        .form-hint New SQL connectors start on localhost by default.

      .form-group
        = f.label "sql_database[port]", "Port", class: "form-label"
        = f.number_field "sql_database[port]",
                         value: connector.port,
                         class: "form-input",
                         placeholder: connector.default_port,
                         min: 1,
                         max: 65_535,
                         data: { sql_database_connector_form_target: "portInput" }
        .form-hint Leave blank for the adapter default port.

      .form-group
        .form-check
          = check_box_tag "sql_database[ssl_enabled]",
                          "1",
                          connector.ssl_enabled?,
                          class: "form-check-input",
                          id: "sql_database_ssl_enabled",
                          data: { sql_database_connector_form_target: "sslInput" }
          = label_tag "sql_database_ssl_enabled", "Enable SSL", class: "form-check-label"
        .form-hint Turn this on before loading databases if the server requires encrypted transport.

    .form-grid.mt-4
      .form-group
        .sql-connector-wizard__field-label-row
          = f.label "sql_database[database_name]", class: "form-label" do
            Database Name
            %span.text-danger-500.ml-0.5 *
          .sql-connector-wizard__database-action{ class: ("hidden" unless show_database_select), data: { sql_database_connector_form_target: "databaseLoadRow" } }
            = button_tag type: "button",
                         class: "btn btn-secondary btn-sm",
                         data: { action: "click->sql-database-connector-form#loadDatabases", sql_database_connector_form_target: "databaseLoadBtn" } do
              %i.fa-solid.fa-arrows-rotate.mr-1
              Load Databases
        .sql-connector-wizard__database-field
          .sql-connector-wizard__database-control.space-y-0
            .block{ class: ("hidden" unless show_database_select), data: { sql_database_connector_form_target: "databaseSelectWrapper" } }
              = select_tag "sql_database[database_name]",
                           options_for_select(database_options, selected_database),
                           include_blank: "Select a database...",
                           class: "form-input form-select",
                           disabled: !show_database_select,
                           required: show_database_select,
                           data: { sql_database_connector_form_target: "databaseSelect" }
            .block{ class: ("hidden" if show_database_select), data: { sql_database_connector_form_target: "databaseManualWrapper" } }
              = f.text_field "sql_database[database_name]",
                             value: connector.database_name,
                             class: "form-input",
                             placeholder: database_placeholder,
                             required: fields_mode && !show_database_select,
                             disabled: show_database_select,
                             data: { sql_database_connector_form_target: "databaseManualInput" }
        .form-hint{ data: { sql_database_connector_form_target: "databaseHint" } }= database_hint

      .form-group
        = f.label "sql_database[username]", "Username", class: "form-label"
        = f.text_field "sql_database[username]", value: connector.username, class: "form-input", placeholder: "db_user"

      .form-group
        = f.label "sql_database[encrypted_password]", "Password", class: "form-label"
        = f.password_field "sql_database[encrypted_password]", class: "form-input", placeholder: "••••••••"

    .ui-wizard__status.is-info.mt-4{ data: { sql_database_connector_form_target: "databaseResult" } }
      %i.fa-solid.fa-circle-info
      %p= database_status_message

  .ui-wizard__source-body.mt-4{ class: (fields_mode ? "hidden" : nil), data: { sql_database_connector_form_target: "connectionStringBody" } }
    .form-group
      = f.label "sql_database[connection_string]", class: "form-label" do
        Connection String
        %span.text-danger-500.ml-0.5 *
      = f.text_field "sql_database[connection_string]",
                     value: connector.connection_string,
                     class: "form-input font-mono",
                     placeholder: "postgresql://user:pass@localhost:5432/database",
                     required: !fields_mode,
                     data: { sql_database_connector_form_target: "connectionStringInput" }
      .form-hint Provide a full URI when the environment already gives you a connection string.
