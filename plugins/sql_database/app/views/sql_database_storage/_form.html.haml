- available_connectors = current_tenant.connectors.sql_databases.enabled.ordered
- state = Rag::SqlDatabaseStorageWizardState.new(steppable)
- connector_options = options_for_select(available_connectors.map { |connector| [connector.name, connector.id] }, steppable.connector_id)
- storage_mode = state.storage_mode
- preview_url = edit_admin_rag_flow_step_path(rag_flow, "storage")
- status = state.status
- status_icon = wizard_status_icon(status.kind)
- wizard = build_wizard_component(eyebrow: "SQL Storage", title: "Configure destination tables", subtitle: "Choose whether this step should write into existing PostgreSQL tables or create new ones, then map the chunk schema and load behavior.", steps: [{ label: "Connect", target_id: "sql-storage-step-connect" }, { label: "Choose destination", target_id: "sql-storage-step-destination" }, { label: "Map schema", target_id: "sql-storage-step-schema" }, { label: "Load behavior", target_id: "sql-storage-step-load" }])
- stylesheet_urls = [asset_path("plugin_sql_database_wizard.css"), asset_path("plugin_sql_database_storage_wizard.css")]
- content_for :head do
  = stylesheet_link_tag "plugin_sql_database_wizard", "data-turbo-track": "reload"
  = stylesheet_link_tag "plugin_sql_database_storage_wizard", "data-turbo-track": "reload"

- if available_connectors.any?
  .ui-wizard.ui-wizard--flush-card.sql-storage-wizard{
    data: {
      controller: "wizard-preview sql-database-wizard-styles",
      "wizard-preview-url-value": preview_url,
      "wizard-preview-frame-id-value": "rag-step-configurator",
      sql_database_wizard_styles_urls_value: stylesheet_urls.to_json,
    },
  }
    = f.hidden_field :auto_create_tables, value: storage_mode == "new" ? "1" : "0"
    - steppable.metadata_field_mappings.each do |metadata_key, column_name|
      = hidden_field_tag "sql_database_storage[metadata_field_mappings][#{metadata_key}]", column_name
    - steppable.metadata_column_types.each do |metadata_key, sql_type|
      = hidden_field_tag "sql_database_storage[metadata_column_types][#{metadata_key}]", sql_type

    .ui-wizard__shell
      = render "shared/wizard/header", wizard:

      .ui-wizard__panel#sql-storage-step-connect
        = render "shared/wizard/section_head",
                 step: wizard.steps[0],
                 copy: "Choose the PostgreSQL connector where documents and chunk embeddings should be stored."
        .form-group{ data: { controller: "choices", choices_search_value: "false" } }
          = f.label :connector_id, class: "form-label" do
            SQL Database Connector
            %span.text-danger-500.ml-0.5 *
          = f.select :connector_id,
                     connector_options,
                     { include_blank: "Select a connector..." },
                     class: "form-input form-select",
                     required: true,
                     data: { action: "change->wizard-preview#preview", choices_target: "select" }
          .form-hint The storage connector must be PostgreSQL with pgvector available.

      = render partial: "wizard_destination_details",
               locals: { f:, steppable:, state:, storage_mode:, step: wizard.steps[1] }
      -# haml-lint sibling render separator
      = render partial: "wizard_schema_mapping",
               locals: { f:, steppable:, state:, status:, status_icon:, storage_mode:, step: wizard.steps[2] }
      -# haml-lint sibling render separator
      = render partial: "wizard_loading_behavior",
               locals: { f:, steppable:, storage_mode:, step: wizard.steps[3] }
- else
  .text-center.py-8
    %i.fa-solid.fa-plug.text-xl.text-text-muted.mb-2
    %p.text-sm.text-text-secondary.mb-3 No enabled SQL database connectors available.
    = link_to new_admin_connector_path(type: "sql_database"), class: "btn btn-secondary btn-sm" do
      %i.fa-solid.fa-plus.mr-1
      Create Connector
