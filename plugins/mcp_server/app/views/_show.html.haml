/ ── MCP Server Connection Details ──
/ Locals: connector (Connector with mcp_server configurator)
.detail-grid
  .detail-item
    .detail-label Transport
    .detail-value= connector.transport_label
  .detail-item
    .detail-label Endpoint
    .detail-value.font-mono.text-xs.break-all.whitespace-normal= connector.display_endpoint
  - if connector.stdio?
    - if connector.parsed_args.any?
      .detail-item
        .detail-label Arguments
        .detail-value.font-mono.text-xs= connector.parsed_args.join(", ")
    - if connector.parsed_env_vars.any?
      .detail-item
        .detail-label Env Variables
        .detail-value= connector.parsed_env_vars.keys.join(", ")
  - else
    - if connector.http_version.present?
      .detail-item
        .detail-label HTTP Version
        .detail-value= connector.http_version == "http2" ? "HTTP/2" : "HTTP/1.1"
    - if connector.parsed_headers.any?
      .detail-item
        .detail-label Custom Headers
        .detail-value= connector.parsed_headers.keys.join(", ")
    - if connector.oauth_enabled?
      .detail-item
        .detail-label OAuth
        .detail-value
          %span.badge.badge-success Enabled
          - if connector.oauth_grant_type.present?
            %span.text-xs.ml-1.text-text-muted= connector.oauth_grant_type.titleize
  .detail-item
    .detail-label Timeout
    .detail-value #{connector.request_timeout}ms

.mt-4.pt-4.border-t.border-border-default{ data: { controller: "mcp-server-connector-test", mcp_server_connector_test_endpoint_value: admin_test_connection_mcp_server_connectors_path, mcp_server_connector_test_payload_value: { mcp_server: connector.connection_test_params }.to_json } }
  .flex.items-center.gap-3
    %button.btn.btn-secondary{ type: "button", data: { action: "click->mcp-server-connector-test#test", mcp_server_connector_test_target: "testBtn" } }
      %i.fa-solid.fa-plug-circle-check.mr-1
      Test Connection
  .test-connection-result.mt-3{ data: { mcp_server_connector_test_target: "testResult" } }
