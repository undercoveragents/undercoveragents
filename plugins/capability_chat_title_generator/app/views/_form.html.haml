/ ── Chat Title Generator — Capability Settings ──
/ Locals:
/   capability_config — Capabilities::TitleGenerator configurator
/   available_llm_connectors — Array of enabled LLM Connector records

- tg = capability_config
- tg_connector = tg.use_custom_llm_config? ? tg.resolve_connector(tg.agent) : nil
- tg_provider = tg_connector.provider if tg_connector&.connector_type == "llm_provider"
- tg_models = tg_provider.present? ? Model.where(provider: tg_provider).order(:name).select(:model_id, :name, :provider) : Model.none

.form-grid
  .form-group
    = label_tag "capability_max_length", class: "form-label" do
      Max Title Length
      %span.text-sm.font-normal.text-text-muted.ml-1 (characters)
    = number_field_tag "capability[max_length]", tg.max_length, min: 5, max: 200, step: 1, class: "form-input", id: "capability_max_length"
    .form-hint
      Maximum number of characters for the generated title.
      Default: #{Capabilities::TitleGenerator::DEFAULT_MAX_LENGTH}.

  .form-group
    = label_tag "capability_max_turns", class: "form-label" do
      Max Turns
    = number_field_tag "capability[max_turns]", tg.max_turns, min: 1, max: 50, step: 1, class: "form-input", id: "capability_max_turns"
    .form-hint
      Number of conversation turns to consider for title generation. The title will be
      generated or updated on each turn up to this limit.
      Default: #{Capabilities::TitleGenerator::DEFAULT_MAX_TURNS}.

.mt-4
  .form-group.mb-4
    %label.form-label LLM Configuration
    .flex.flex-col.gap-3
      %label.flex.items-start.gap-3.cursor-pointer
        = radio_button_tag "capability[llm_config_source]", "inherit", tg.inherit_llm_config?,
                           class: "form-radio mt-0.5",
                           data: { action: "change->capability-config#onSourceChange" }
        .flex-1
          .text-sm.font-medium.text-text-primary Inherit from agent
          .text-xs.text-text-muted.mt-0.5
            Use the same LLM connection, model, and temperature as the parent agent.
      %label.flex.items-start.gap-3.cursor-pointer
        = radio_button_tag "capability[llm_config_source]", "custom", tg.use_custom_llm_config?,
                           class: "form-radio mt-0.5",
                           data: { action: "change->capability-config#onSourceChange" }
        .flex-1
          .text-sm.font-medium.text-text-primary Custom LLM configuration
          .text-xs.text-text-muted.mt-0.5
            Use a dedicated LLM connection for title generation (e.g. a smaller, faster model).

  .mt-4{ data: { capability_config_target: "customConfig" }, class: ("hidden" unless tg.use_custom_llm_config?) }
    = render "shared/model_config",
             field_prefix: "capability",
             frame_id: "capability_model_select",
             connector_change_action: "change->capability-config#onConnectorChange",
             available_llm_connectors:,
             available_models: tg_models,
             selected_connector_id: tg.llm_connector_id,
             selected_model_id: tg.model_id,
             temperature_value: tg.temperature || Capabilities::TitleGenerator::DEFAULT_TEMPERATURE,
             required: false
