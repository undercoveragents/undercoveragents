- return if flash[:automation_trigger_webhook_secret].blank?

.card.mb-6.border-success-500
  .card-body
    .flex.items-start.gap-3
      .flex.items-center.justify-center.w-8.h-8.rounded-full.shrink-0{ class: "bg-success-500/10 text-success-500" }
        %i.fa-solid.fa-key
      .flex-1
        %h3.text-sm.font-semibold.text-success-500.mb-1 Webhook Secret Generated
        %p.text-xs.text-text-secondary.mb-3 Copy this secret now. It will not be shown again.
        - if automation_trigger.persisted?
          %p.text-xs.text-text-secondary.mb-3
            Send it in the
            %code= AutomationTrigger::WEBHOOK_SECRET_HEADER
            header when POSTing to
            %code.break-all= automation_trigger_webhook_url(automation_trigger)
        .flex.items-center.gap-2{ data: { controller: "clipboard", clipboard_text_value: flash[:automation_trigger_webhook_secret] } }
          %code.text-sm.font-mono.bg-surface-secondary.border.border-border-default.rounded.px-3.py-2.flex-1.break-all= flash[:automation_trigger_webhook_secret]
          %button.btn.btn-secondary.btn-sm{ type: "button", data: { action: "click->clipboard#copy" } }
            %i.fa-solid.fa-copy.mr-1
            Copy
