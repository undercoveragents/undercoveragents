- content_for(:title, "New Automation Trigger — #{@schedulable.name} — #{APP_NAME}")
- if @automation_trigger.present?
  - title = @automation_trigger.trigger_schedule? ? "New Schedule Trigger" : "New Webhook Trigger"
  = render_page_hero(title:, variant: :compact, title_icon: automation_trigger_icon(@automation_trigger), record_title: @schedulable.name, back_link: { label: "Back to Automation", url: automation_trigger_collection_path(@schedulable) }, actions: [page_hero_form_action(label: "Create Trigger", form_id: "automation-trigger-form", icon: "fa-solid fa-plus")])

  = render "form", schedulable: @schedulable, automation_trigger: @automation_trigger
- else
  = render_page_hero(title: "Choose Automation Trigger Type", description: "Start with how the record should fire, then configure the trigger details.", variant: :compact, title_icon: "fa-solid fa-clock", record_title: @schedulable.name, back_link: { label: "Back to Automation", url: automation_trigger_collection_path(@schedulable) })

  .connector-wizard
    %h2.text-lg.font-semibold.mb-6.text-text-primary Choose Trigger Type

    .grid.grid-cols-1.md:grid-cols-2.gap-6
      - @trigger_types.each do |trigger_type|
        = link_to automation_trigger_new_path(@schedulable, type: trigger_type[:key]), class: "connector-type-card", data: { turbo_frame: "app-content-frame" } do
          .flex.items-start.justify-between.gap-3.mb-4
            .connector-type-icon.mb-0
              %i{ class: "#{trigger_type[:icon]} text-2xl" }
          %h3.text-lg.font-semibold.mb-1.text-text-primary= trigger_type[:label]
          %p.text-sm.text-text-secondary= trigger_type[:description]
