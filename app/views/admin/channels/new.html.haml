- content_for(:title, "New Channel - #{APP_NAME}")
- if @channel.present?
  - actions = [page_hero_form_action(label: "Create Channel", form_id: "channel-form", icon: "fa-solid fa-plus")]
  = render_page_hero(title: "New Channel", variant: :compact, title_icon: "fa-solid fa-tower-broadcast", back_link: { label: "Back to Channels", url: admin_channels_path }, actions:)

  = render "form", channel: @channel, connectors: @connectors, available_agents: @available_agents, available_missions: @available_missions, selected_target_kind: @selected_target_kind, selected_agent_id: @selected_agent_id, selected_mission_id: @selected_mission_id, selected_agent_ids: @selected_agent_ids, selected_mission_ids: @selected_mission_ids
- else
  = render_page_hero(title: "Choose Channel Type", description: "Start with the delivery surface, then configure targets and type-specific behavior.", variant: :compact, title_icon: "fa-solid fa-tower-broadcast", back_link: { label: "Back to Channels", url: admin_channels_path })

  .connector-wizard
    %h2.text-lg.font-semibold.mb-6.text-text-primary Choose Channel Type

    .grid.grid-cols-1.md:grid-cols-2.lg:grid-cols-4.gap-6
      - @channel_types.each do |channel_type|
        = link_to new_admin_channel_path(type: channel_type[:key]), class: "connector-type-card", data: { turbo_frame: "app-content-frame" } do
          .flex.items-start.justify-between.gap-3.mb-4
            .connector-type-icon.mb-0
              %i{ class: "#{channel_type[:icon]} text-2xl" }
          %h3.text-lg.font-semibold.mb-1.text-text-primary= channel_type[:label]
          - if channel_type[:description].present?
            %p.text-sm.text-text-secondary= channel_type[:description]

      - @channel_placeholders.each do |channel_type|
        .connector-type-card.connector-type-card--disabled{ aria: { disabled: true }, data: { channel_placeholder: true } }
          .flex.items-start.justify-between.gap-3.mb-4
            .connector-type-icon.mb-0
              %i{ class: "#{channel_type[:icon]} text-2xl" }
            %span.badge.badge-warning Coming soon
          %h3.text-lg.font-semibold.mb-1.text-text-primary= channel_type[:label]
          %p.text-sm.text-text-secondary= channel_type[:description]
