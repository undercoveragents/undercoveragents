- content_for(:title, "Automation — #{@mission.name} — #{APP_NAME}")
- schedule_trigger = MissionTrigger.new(mission: @mission, trigger_type: "schedule", enabled: true, timezone: "UTC")
- webhook_trigger = MissionTrigger.new(mission: @mission, trigger_type: "webhook", enabled: true, timezone: "UTC")
- actions = []
- actions << policy_page_hero_action(schedule_trigger, :create?, label: "New Schedule", url: new_admin_mission_mission_trigger_path(@mission, type: :schedule), icon: "fa-solid fa-clock", style: :secondary)
- actions << policy_page_hero_action(webhook_trigger, :create?, label: "New Webhook", url: new_admin_mission_mission_trigger_path(@mission, type: :webhook), icon: "fa-solid fa-link", style: :primary)
= render_page_hero(title: "Automation", variant: :compact, title_icon: "fa-solid fa-clock", record_title: @mission.name, back_link: { label: "Back to Mission", url: designer_admin_mission_path(@mission) }, actions:)

- if @mission_triggers.any?
  .card-grid.card-grid--entities
    - @mission_triggers.each do |mission_trigger|
      .card.entity-card
        .card-body.entity-card__body
          .entity-card__header
            .entity-card__identity
              .entity-card__icon
                %i{ class: mission_trigger_icon(mission_trigger) }
              .entity-card__identity-copy
                %h3.entity-card__title.text-text-primary= mission_trigger.name
                %p.entity-card__subtitle= mission_trigger.trigger_schedule? ? "Cron automation" : "External webhook trigger"
            .entity-card__status.flex.items-center.gap-2
              - mission_trigger_status_badges(mission_trigger).each do |badge|
                = badge

          - if mission_trigger.trigger_schedule?
            %p.entity-card__description
              %strong Cron:
              %code= mission_trigger.cron_expression
              %span •
              %span= mission_trigger.timezone
            %p.entity-card__description= mission_trigger_next_run_label(mission_trigger)
          - else
            %p.entity-card__description.break-all
              %strong URL:
              %code= mission_trigger_webhook_url(mission_trigger)
            %p.entity-card__description
              %strong Secret:
              %code= mission_trigger.masked_webhook_secret

          .entity-card__footer.justify-between.items-start.gap-4
            .space-y-1
              %span.entity-card__timestamp
                %i.fa-solid.fa-clock
                = mission_trigger_last_activity(mission_trigger)
              - if mission_trigger.last_mission_run.present?
                = link_to admin_mission_control_run_path(mission_trigger.last_mission_run), class: "text-xs text-accent no-underline hover:underline", data: { turbo_frame: "app-content-frame" } do
                  %i.fa-solid.fa-satellite-dish.mr-1
                  View last run
              - if mission_trigger.last_error.present?
                %p.text-xs.text-danger-500= mission_trigger.last_error
            .flex.flex-wrap.items-center.justify-end.gap-2
              - if mission_trigger.trigger_webhook?
                = link_to regenerate_secret_admin_mission_mission_trigger_path(@mission, mission_trigger), class: "btn btn-secondary btn-sm", data: { turbo_method: :post, controller: "confirm", confirm_title_value: "Regenerate Webhook Secret", confirm_message_value: "Generate a new webhook secret? Existing callers will stop working until they update their secret." } do
                  %i.fa-solid.fa-rotate.mr-1
                  Regenerate Secret
              = link_to edit_admin_mission_mission_trigger_path(@mission, mission_trigger), class: "btn btn-secondary btn-sm", data: { turbo_frame: "app-content-frame" } do
                %i.fa-solid.fa-pen.mr-1
                Edit
              = link_to admin_mission_mission_trigger_path(@mission, mission_trigger), class: "btn btn-danger-outline btn-sm", data: { turbo_method: :delete, controller: "confirm", confirm_title_value: "Delete Automation Trigger", confirm_message_value: "Delete #{mission_trigger.name}? Scheduled runs and webhook access will stop immediately." } do
                %i.fa-solid.fa-trash.mr-1
                Delete
- else
  = render_page_empty_state(title: "No automation triggers yet", body: "Add a schedule or webhook to run this mission automatically.") do
    = link_to new_admin_mission_mission_trigger_path(@mission, type: :schedule), class: "btn btn-secondary", data: { turbo_frame: "app-content-frame" } do
      %i.fa-solid.fa-clock.mr-1
      New Schedule
    -# spacer between sibling buttons
    = link_to new_admin_mission_mission_trigger_path(@mission, type: :webhook), class: "btn btn-primary", data: { turbo_frame: "app-content-frame" } do
      %i.fa-solid.fa-link.mr-1
      New Webhook
