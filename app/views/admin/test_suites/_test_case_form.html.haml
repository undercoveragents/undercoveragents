#test-case-form
  = form_with url: admin_test_suite_test_cases_path(test_suite), method: :post, class: "space-y-4" do
    - if test_suite.agent?
      .form-group
        %label.form-label Name
        %input.form-input{ name: "test_case[name]", type: "text", placeholder: "Optional label for this case" }

      .form-group
        %label.form-label Prompt
        %textarea.form-input{ name: "test_case[prompt]", rows: 3, placeholder: "What question should the agent answer?", required: true }

      .form-group
        %label.form-label Expected Answer
        %textarea.form-input{ name: "test_case[expected_answer]", rows: 3, placeholder: "What is the correct or expected response?", required: true }

      .form-group
        %label.form-label Match Type
        %select.form-select{ name: "test_case[match_type]" }
          %option{ value: "semantic", selected: true } Semantic (AI comparison)
          %option{ value: "exact" } Exact Match

      .grid.grid-cols-1.gap-3{ class: "md:grid-cols-3" }
        .form-group
          %label.form-label Scenario Key
          %input.form-input{ name: "test_case[scenario_key]", type: "text", placeholder: "e.g., knowledge-01" }
        .form-group
          %label.form-label Category
          %input.form-input{ name: "test_case[category]", type: "text", placeholder: "e.g., knowledge" }
        .form-group
          %label.form-label Complexity
          %select.form-select{ name: "test_case[complexity]" }
            %option{ value: "" } —
            %option{ value: "low" } Low
            %option{ value: "medium" } Medium
            %option{ value: "high" } High

      .form-group
        %label.form-label Fixture Key
        %select.form-select{ name: "test_case[fixture_key]" }
          %option{ value: "" } None
          %option{ value: "agent_alpha_benchmark" } Agent Alpha benchmark fixture

      .grid.grid-cols-1.gap-3{ class: "md:grid-cols-2" }
        .form-group
          %label.form-label Expected Child Builtin
          %input.form-input{ name: "test_case[expected_child_builtin_key]", type: "text", placeholder: "e.g., mission_designer" }
        .form-group
          %label.form-label Expected Tool Names
          %input.form-input{ name: "test_case[expected_tool_names]", type: "text", placeholder: "Comma-separated tool names" }

      .form-group
        %label.inline-flex.items-center.gap-2.text-sm.text-text-secondary
          %input.form-checkbox{ name: "test_case[disallow_child_chats]", type: "checkbox", value: "1" }
          Disallow child chats

      .grid.grid-cols-1.gap-3{ class: "md:grid-cols-2" }
        .form-group
          %label.form-label Required Keywords
          %textarea.form-input{ name: "test_case[required_keywords]", rows: 2, placeholder: "One keyword per line or comma-separated" }
        .form-group
          %label.form-label Forbidden Keywords
          %textarea.form-input{ name: "test_case[forbidden_keywords]", rows: 2, placeholder: "One keyword per line or comma-separated" }
    - else
      .form-group
        %label.form-label
          Name
          %span.text-danger-500.ml-0.5 *
        %input.form-input{ name: "test_case[name]", type: "text", placeholder: "e.g., Happy path order processing", required: true }

      - fields = test_suite.input_fields
      - if fields.any?
        .form-group
          %label.form-label.mb-2 Input Variables
          .space-y-3.rounded-lg.border.border-border-default.p-3
            - fields.each do |field|
              .form-group.mb-0
                %label.form-label.text-xs
                  = field["name"]
                  - if field["required"]
                    %span.text-danger-500.ml-0.5 *
                  %span.text-text-muted.ml-1 (#{field["type"]})
                - case field["type"]
                - when "string"
                  %input.form-input{ name: "test_case[input_variables][#{field["name"]}]", type: "text", placeholder: field["description"].presence, required: field["required"] }
                - when "number"
                  %input.form-input{ name: "test_case[input_variables][#{field["name"]}]", type: "number", step: "any", placeholder: field["description"].presence, required: field["required"] }
                - when "boolean"
                  %select.form-select{ name: "test_case[input_variables][#{field["name"]}]" }
                    %option{ value: "" } —
                    %option{ value: "true" } True
                    %option{ value: "false" } False
                - when "date"
                  %input.form-input{ name: "test_case[input_variables][#{field["name"]}]", type: "date", required: field["required"] }
                - when "datetime"
                  %input.form-input{ name: "test_case[input_variables][#{field["name"]}]", type: "datetime-local", required: field["required"] }
                - when "json"
                  %textarea.form-input{ name: "test_case[input_variables][#{field["name"]}]", rows: 2, placeholder: '{"key": "value"}' }
                - when "file"
                  %input.form-input{ name: "test_case[input_variables][#{field["name"]}]", type: "file" }
                - when "string_array", "number_array", "date_array", "datetime_array", "boolean_array", "file_array"
                  %textarea.form-input{ name: "test_case[input_variables][#{field["name"]}]", rows: 2, placeholder: "One value per line" }
                  .form-hint Enter one value per line.
                - else
                  %input.form-input{ name: "test_case[input_variables][#{field["name"]}]", type: "text", placeholder: field["description"].presence }
      - else
        .form-group
          %label.form-label Input Variables (JSON)
          %textarea.form-input{ name: "test_case[input_variables]", rows: 4, placeholder: '{"order_id": 123, "amount": 99.99}' }
          .form-hint JSON object with input variables to seed the mission run.

      .form-group
        %label.form-label Expected Status
        %select.form-select{ name: "test_case[expected_status]" }
          %option{ value: "completed", selected: true } Completed
          %option{ value: "failed" } Failed

      .form-group
        %label.form-label Expected Variables (JSON)
        %textarea.form-input{ name: "test_case[expected_variables]", rows: 4, placeholder: '{"result": "success", "total": 99.99}' }
        .form-hint JSON object with expected output variables to assert against.

      .form-group
        %label.form-label Match Type
        %select.form-select{ name: "test_case[match_type]" }
          %option{ value: "exact", selected: true } Exact (all variables must match, no extras)
          %option{ value: "partial" } Partial (only listed variables must match)

    .flex.justify-end
      %button.btn.btn-primary{ type: "submit" }
        %i.fa-solid.fa-plus.mr-1
        Add Case
