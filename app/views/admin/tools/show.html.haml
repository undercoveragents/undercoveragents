- content_for(:title, "#{@tool.name} — #{APP_NAME}")
- content_for(:head) { tag.meta(name: "turbo-cache-control", content: "no-cache") }
- actions = []
- actions << policy_page_hero_action(@tool, :clone?, label: "Clone", url: clone_admin_tool_path(@tool), icon: "fa-solid fa-copy", style: :secondary, method: :post, data: { controller: "confirm", confirm_title_value: "Clone Tool", confirm_message_value: "Create a cloned copy of #{@tool.name}? The clone will keep the current configuration and open as a new tool.", confirm_confirm_label_value: "Clone", confirm_confirm_icon_value: "fa-solid fa-copy" })
- actions << policy_page_hero_action(@tool, :update?, label: "Edit", url: edit_admin_tool_path(@tool), icon: "fa-solid fa-pen", style: :secondary)
- actions << policy_page_hero_action(@tool, :destroy?, label: "Delete", url: admin_tool_path(@tool), icon: "fa-solid fa-trash", style: :danger_outline, method: :delete, data: { controller: "confirm", confirm_title_value: "Delete Tool", confirm_message_value: "Are you sure you want to delete this tool? This action cannot be undone." })
= render_page_hero(title: "Tool", variant: :compact, title_icon: tool_type_icon(@tool), record_title: @tool.name, back_link: { label: "Back to Tools", url: admin_tools_path }, meta: [tool_status_badge(@tool), tag.span(tool_type_label(@tool), class: "badge badge-neutral")], actions:)

- if @tool.description.present?
  .card.mb-6
    .card-body
      %p.text-sm.text-text-secondary= @tool.description

= render @tool.toolable.show_partial_path, tool: @tool
- if @tool.toolable.respond_to?(:tool_compaction_policy) && !(@tool.toolable.respond_to?(:show_compaction_in_configuration_card?) && @tool.toolable.show_compaction_in_configuration_card?)
  .card.mb-6
    .card-header
      %h3.text-sm.font-semibold.text-text-primary
        %i.fa-solid.fa-sliders.mr-2.text-accent
        Advanced Configuration
    .card-body
      .detail-grid
        .detail-item
          .detail-label Chat History Compaction
          .detail-value= tool_compaction_policy_label(@tool.toolable)
= render "tools/shared/widget_summary", tool: @tool, toolable: @tool.toolable
