= turbo_stream.before "chats-load-more" do
  - @chats.each do |chat|
    = render "playground/chats/chat_item", chat:, current_chat: nil
- if @pagy_chats.next
  = turbo_stream.replace "chats-load-more" do
    = render "playground/chats/load_more", pagy: @pagy_chats, agent: @agent
- else
  = turbo_stream.remove "chats-load-more"
