- content_for(:title, "Edit User — #{APP_NAME}")
- form_id = "user-form"
- back_link = { label: "Back to Users", url: admin_users_path }
= render_page_hero(title: "Edit User", variant: :compact, title_icon: "fa-solid fa-users", record_title: @user.email, back_link:, actions: [page_hero_form_action(label: "Update User", form_id:)])

.card
  .card-body
    = render "form", user: @user, url: admin_user_path(@user), form_id:, available_roles: @available_roles
