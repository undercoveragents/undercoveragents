= f.hidden_field :assigned_tool_ids, value: "", multiple: true, id: nil
= f.hidden_field :runtime_tool_keys, value: "", multiple: true, id: nil
- available_builtin_tools = local_assigns.fetch(:available_builtin_tools, [])

.card.mb-6
  .card-header
    %h3.text-sm.font-semibold.text-text-primary
      %i.fa-solid.fa-wrench.mr-2.text-accent
      Tools
  .card-body
    %p.text-sm.text-text-secondary.mb-4
      Select the tools this agent can use. Operation tools are configured records; built-in runtime tools are application-provided abilities.

    - if available_tools.any?
      %h4.text-xs.font-semibold.uppercase.tracking-wide.text-text-muted.mb-2 Operation Tools
      .space-y-2.mb-5
        - available_tools.each do |tool|
          - checked = agent.tool_ids.include?(tool.id)
          .flex.items-center.gap-3.p-3.rounded-lg.border.transition-colors.cursor-pointer{ class: checked ? "border-accent bg-accent/5" : "border-border-default hover:border-accent" }
            = f.check_box :assigned_tool_ids, { multiple: true, checked:, id: "tool_#{tool.id}", class: "form-check-input" }, tool.id, nil
            = label_tag "tool_#{tool.id}", class: "flex items-center gap-3 flex-1 cursor-pointer" do
              .entity-card__icon
                %i{ class: tool_type_icon(tool) }
              .flex-1.min-w-0
                .text-sm.font-medium.text-text-primary.truncate= tool.name
                .text-xs.text-text-secondary= tool_type_label(tool)
                - if tool.description.present?
                  .text-xs.text-text-muted.mt-1.line-clamp-1= tool.description
    - else
      .text-center.py-6.mb-5.rounded-lg.border.border-dashed.border-border-default
        %i.fa-solid.fa-wrench.text-2xl.text-text-muted.mb-3
        %p.text-sm.text-text-secondary.mb-2 No enabled operation tools available.
        = link_to new_admin_tool_path, class: "btn btn-secondary btn-sm" do
          %i.fa-solid.fa-plus.mr-1
          Create a Tool

    - if available_builtin_tools.any?
      %h4.text-xs.font-semibold.uppercase.tracking-wide.text-text-muted.mb-2 Built-in Runtime Tools
      .space-y-2
        - available_builtin_tools.each do |tool|
          - checked = agent.runtime_tool_keys.include?(tool.key)
          .flex.items-center.gap-3.p-3.rounded-lg.border.transition-colors.cursor-pointer{ class: checked ? "border-accent bg-accent/5" : "border-border-default hover:border-accent" }
            = f.check_box :runtime_tool_keys, { multiple: true, checked:, id: "runtime_tool_#{tool.key.parameterize}", class: "form-check-input" }, tool.key, nil
            = label_tag "runtime_tool_#{tool.key.parameterize}", class: "flex items-center gap-3 flex-1 cursor-pointer" do
              .entity-card__icon
                %i{ class: tool.icon.presence || "fa-solid fa-wrench" }
              .flex-1.min-w-0
                .text-sm.font-medium.text-text-primary.truncate= tool.name
                .text-xs.text-text-secondary= tool.description
                .text-text-muted.mt-1{ class: "text-[11px]" }= tool.key
                - if tool.configuration_hint.present?
                  .text-xs.text-text-muted.mt-1= tool.configuration_hint
    - else
      .text-center.py-6.rounded-lg.border.border-dashed.border-border-default
        %i.fa-solid.fa-cubes.text-2xl.text-text-muted.mb-3
        %p.text-sm.text-text-secondary.mb-2 No built-in runtime tools are available for user agents.
