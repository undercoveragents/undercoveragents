- content_for(:title, "Edit #{@agent.name} Instructions — #{APP_NAME}")
- form_id = "agent-instructions-form"
- back_link = { label: "Back to #{@agent.name}", url: admin_agent_path(@agent) }
= render_page_hero(title: "Edit Instructions", variant: :compact, title_icon: "fa-solid fa-scroll", record_title: @agent.name, back_link:, actions: [page_hero_form_action(label: "Update Instructions", form_id:)])

= form_with model: @agent, url: admin_agent_path(@agent), method: :patch, local: true, html: { class: "agent-form", id: form_id } do
  %input{ type: "hidden", name: "agent[edit_context]", value: "instructions" }
  = render "shared/forms/validation_errors", record: @agent, resource_name: "agent"
  = render "agents/form_instructions_fields", agent: @agent, available_llm_connectors: @available_llm_connectors
