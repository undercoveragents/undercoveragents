- action = connector.persisted? ? admin_connector_path(connector) : admin_connectors_path
- method = connector.persisted? ? :patch : :post
- form_id = local_assigns.fetch(:form_id, "connector-form")

.connector-form-container{ data: { controller: "llm-provider-connector-form" } }
  = form_with url: action, method:, local: true, html: { class: "connector-form", id: form_id } do |f|
    = hidden_field_tag :connector_type, "llm_provider"

    = render "shared/forms/validation_errors", record: connector, resource_name: "connector"

    / Basic Information (shared)
    = render "connectors/forms/shared/basic_info", f:, connector:

    / Provider Selection
    .card.mb-6
      .card-header
        %h3.text-sm.font-semibold.text-text-primary
          %i.fa-solid.fa-cloud.mr-2.text-accent
          Provider
      .card-body
        .form-grid
          .form-group{ data: { controller: "choices", choices_search_value: "false" } }
            = f.label "llm_provider[provider]", class: "form-label" do
              LLM Provider
              %span.text-danger-500.ml-0.5 *
            = f.select "llm_provider[provider]", options_for_select(Connectors::LlmProvider.providers_for_select, connector.provider), { include_blank: "Select a provider..." }, class: "form-input form-select", data: { choices_target: "select", action: "change->llm-provider-connector-form#onProviderChange" }, required: true
            .form-hint Choose the LLM provider you want to connect to.

    / Provider-specific fields (Turbo Frame)
    = turbo_frame_tag "llm_provider_fields" do
      - if connector.provider.present?
        .card.mb-6
          .card-header
            %h3.text-sm.font-semibold.text-text-primary
              %i.fa-solid.fa-key.mr-2.text-accent
              = t("connectors.llm_provider.form.provider_config")
          .card-body
            .form-grid
              = render "llm_provider_fields", connector:

    / Advanced Settings
    .card.mb-6
      .card-header.cursor-pointer{ data: { action: "click->llm-provider-connector-form#toggleAdvanced" } }
        .flex.items-center.justify-between
          %h3.text-sm.font-semibold.text-text-primary
            %i.fa-solid.fa-sliders.mr-2.text-accent
            Advanced Settings
          %i.fa-solid.fa-chevron-down.text-xs.transition-transform.duration-200.text-text-muted{ data: { llm_provider_connector_form_target: "advancedChevron" } }
      .card-body.hidden{ data: { llm_provider_connector_form_target: "advancedPanel" } }
        .form-grid
          .form-group
            = f.label "llm_provider[http_proxy]", "HTTP Proxy", class: "form-label"
            = f.text_field "llm_provider[http_proxy]", value: connector.http_proxy, class: "form-input font-mono", placeholder: "http://proxy:8080"

          .form-group
            = f.label "llm_provider[request_timeout]", "Request Timeout (s)", class: "form-label"
            = f.number_field "llm_provider[request_timeout]", value: connector.request_timeout, class: "form-input", min: 1, max: 600
            .form-hint Default: 120s.

          .form-group
            = f.label "llm_provider[max_retries]", "Max Retries", class: "form-label"
            = f.number_field "llm_provider[max_retries]", value: connector.max_retries, class: "form-input", min: 0, max: 10
            .form-hint Default: 3. Set to 0 to disable retries.
