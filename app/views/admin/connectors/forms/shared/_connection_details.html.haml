/ ── Connection Details ──
/ Shared partial: renders host, port, database, username, password fields
/ with connection string toggle.
/ Locals: f (form builder), connector (polymorphic connector record),
/         field_prefix (String, e.g. "sql_database"),
/         show_adapter (Boolean, default false — SQL shows adapter dropdown),
/         default_port_placeholder (Integer/String, default "5432")
- field_prefix ||= "sql_database"
- show_adapter ||= false
- default_port_placeholder ||= "5432"
- controller_identifier ||= "connector-form"
- controller_data_key ||= controller_identifier.tr("-", "_")

.card.mb-6
  .card-header
    .flex.items-center.justify-between
      %h3.text-sm.font-semibold.text-text-primary
        %i.fa-solid.fa-link.mr-2.text-accent
        Connection Details
      %button.btn.btn-secondary.btn-sm{ type: "button", data: { action: "click->#{controller_identifier}#toggleConnectionMode", "#{controller_data_key}_target": "connectionModeBtn" } }
        %i.fa-solid.fa-exchange-alt.mr-1
        Use Connection String
  .card-body
    / Individual fields mode
    .connection-fields{ data: { "#{controller_data_key}_target": "connectionFields" } }
      .form-grid
        - if show_adapter
          .form-group{ data: { controller: "choices", choices_search_value: "false" } }
            = f.label "#{field_prefix}[adapter_type]", "Database Type", class: "form-label"
            = f.select "#{field_prefix}[adapter_type]", options_for_select(Connectors::SqlDatabase::ADAPTER_TYPES.map { |a| [a.titleize, a] }, connector.adapter_type), {}, class: "form-input form-select", data: { choices_target: "select", action: "change->#{controller_identifier}#onAdapterChange" }

        .form-group
          = f.label "#{field_prefix}[host]", class: "form-label" do
            Host
            %span.text-danger-500.ml-0.5 *
          = f.text_field "#{field_prefix}[host]", value: connector.host, class: "form-input", placeholder: "localhost", required: true

        .form-group
          = f.label "#{field_prefix}[port]", "Port", class: "form-label"
          = f.number_field "#{field_prefix}[port]", value: connector.port, class: "form-input", placeholder: default_port_placeholder, min: 1, max: 65_535
          .form-hint Leave blank for default port.

        .form-group
          = f.label "#{field_prefix}[database_name]", class: "form-label" do
            Database Name
            %span.text-danger-500.ml-0.5 *
          = f.text_field "#{field_prefix}[database_name]", value: connector.database_name, class: "form-input", placeholder: "my_database", required: true

        .form-group
          = f.label "#{field_prefix}[username]", "Username", class: "form-label"
          = f.text_field "#{field_prefix}[username]", value: connector.username, class: "form-input", placeholder: "db_user"

        .form-group
          = f.label "#{field_prefix}[encrypted_password]", "Password", class: "form-label"
          = f.password_field "#{field_prefix}[encrypted_password]", class: "form-input", placeholder: "••••••••"

    / Connection string mode
    .connection-string-field.hidden{ data: { "#{controller_data_key}_target": "connectionStringField" } }
      .form-group
        = f.label "#{field_prefix}[connection_string]", class: "form-label" do
          Connection String
          %span.text-danger-500.ml-0.5 *
        = f.text_field "#{field_prefix}[connection_string]", value: connector.connection_string, class: "form-input font-mono", placeholder: "postgresql://user:pass@host:5432/database"
        .form-hint Provide a full connection URI. This overrides individual fields.
