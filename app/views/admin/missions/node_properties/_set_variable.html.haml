/ ── Set Variable Node Configuration ──
.ms-prop-field
  %label.ms-prop-label
    Variables
    %span.ms-prop-required *
    %button.ms-prop-add-btn{ type: "button", data: { action: "click->mission#addAssignment" } }
      %i.fa-solid.fa-plus
  .ms-prop-kv-list{ data: { "mission-target": "propAssignments", "kv-type": "assignments" } }
    - presenter.assignments.each do |key, value|
      .ms-prop-kv-row
        %input.ms-prop-kv-key{ type: "text", placeholder: "Variable name", value: key, data: { action: "blur->mission#syncKv" } }
        %span.ms-prop-kv-sep =
        = render "shared/expression_editor", value:, variables: presenter.selectable_upstream_variables, prop_key: "", placeholder: "Expression", multiline: false, rows: 1, data_action: "blur->mission#syncKv input->mission#syncKv"
        %button.ms-prop-kv-remove{ type: "button", data: { action: "click->mission#removeKvRow" } }
          %i.fa-solid.fa-xmark
  .ms-prop-hint.ms-prop-hint-vars
    %i.fa-solid.fa-circle-info
    Each row defines a variable. Left: variable name. Right: an expression or literal value. Type
    %code @
    to insert a variable.
  -# expression guide trigger
  = render "shared/expression_guide_link"
