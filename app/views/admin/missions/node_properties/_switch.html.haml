/ ── Switch Node Configuration ──
.ms-prop-field
  %label.ms-prop-label
    Switch Expression
    %span.ms-prop-required *
  = render "shared/expression_editor", value: presenter.data("expression"), variables: presenter.selectable_upstream_variables, prop_key: "expression", placeholder: "e.g. status, category", rows: 2
  .ms-prop-hint.ms-prop-hint-vars
    %i.fa-solid.fa-circle-info
    Enter a variable name or expression. Its value will be matched against the cases below. Type
    %code @
    to insert a variable.
  -# expression guide trigger
  = render "shared/expression_guide_link"
/ Cases
.ms-prop-field
  %label.ms-prop-label
    Cases
    %button.ms-prop-add-btn{ type: "button", data: { action: "click->mission#addCase" } }
      %i.fa-solid.fa-plus
  .ms-prop-kv-list{ data: { "mission-target": "propCases", "kv-type": "cases" } }
    - presenter.cases.each do |key, value|
      .ms-prop-kv-row
        %input.ms-prop-kv-key{ type: "text", placeholder: "Value", value: key, data: { action: "blur->mission#syncKv" } }
        %span.ms-prop-kv-sep =
        %input.ms-prop-kv-value{ type: "text", placeholder: "Port name", value:, data: { action: "blur->mission#syncKv" } }
        %button.ms-prop-kv-remove{ type: "button", data: { action: "click->mission#removeKvRow" } }
          %i.fa-solid.fa-xmark
  %span.ms-prop-hint Each case maps a value to a named output port. If no case matches, the Default port is used.
