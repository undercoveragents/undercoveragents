/ ── Condition Node Configuration ──
.ms-prop-field
  %label.ms-prop-label
    Condition Expression
    %span.ms-prop-required *
  = render "shared/expression_editor", value: presenter.data("expression"), variables: presenter.selectable_upstream_variables, prop_key: "expression", placeholder: "e.g. x > 5, status == 'active'", rows: 3
  .ms-prop-hint.ms-prop-hint-vars
    %i.fa-solid.fa-circle-info
    Write a logical expression using upstream variables. Routes to
    %strong True
    or
    %strong False
    port. Type
    %code @
    to insert a variable.
  -# expression guide trigger
  = render "shared/expression_guide_link"
