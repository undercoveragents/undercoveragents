/ ── Text Template Node Configuration ──
.ms-prop-field
  %label.ms-prop-label
    Template
    %span.ms-prop-required *
  = render "shared/expression_editor", value: presenter.data("template"), variables: presenter.selectable_upstream_variables, prop_key: "template", placeholder: "Hello {{user_name}}, your score is {{score}}.", rows: 6
  .ms-prop-hint.ms-prop-hint-vars
    %i.fa-solid.fa-circle-info
    Use
    %code {{variable}}
    syntax to interpolate upstream variables. Produces a single
    %code text
    output. Type
    %code @
    to insert a variable.
  -# expression guide trigger
  = render "shared/expression_guide_link"
