/ ── Filter Node Configuration ──
.ms-prop-field
  %label.ms-prop-label
    Collection
    %span.ms-prop-required *
  = render "shared/expression_editor", value: presenter.data("collection"), variables: presenter.selectable_upstream_variables, prop_key: "collection", placeholder: "Variable name or JSON array", rows: 2
/ Expression
.ms-prop-field
  %label.ms-prop-label
    Filter Expression
    %span.ms-prop-required *
  = render "shared/expression_editor", value: presenter.data("expression"), variables: presenter.selectable_upstream_variables, prop_key: "expression", placeholder: "e.g. item > 5, item != 'exclude'", rows: 2
  .ms-prop-hint.ms-prop-hint-vars
    %i.fa-solid.fa-circle-info
    Expression evaluated per item. Use
    %code item
    to reference the current element. Routes to
    %strong Match
    or
    %strong No Match
    port. Type
    %code @
    to insert a variable.
  -# expression guide trigger
  = render "shared/expression_guide_link"
