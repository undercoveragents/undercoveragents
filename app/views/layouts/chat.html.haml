!!!
- client_name = current_client&.dig(:name) || APP_NAME
- sidebar_list = capture do
  - if defined?(@chats) && @chats.any?
    - @chats.each do |chat|
      = render "chats/chat_item", chat:, current_chat: defined?(@chat) ? @chat : nil
    = render "chats/load_more", pagy: @pagy_chats if defined?(@pagy_chats) && @pagy_chats.next
- sidebar_footer = capture do
  %button.sidebar-user-btn{ type: "button", data: { action: "click->user-menu#toggle" } }
    .sidebar-user-avatar
      = current_user&.initials || "?"
    .sidebar-user-info
      .sidebar-user-name= current_user&.display_name || "Guest"
      .sidebar-user-email= current_user&.email
    %i.fa-solid.fa-ellipsis-vertical.sidebar-user-chevron
  .sidebar-user-dropdown{ data: { "user-menu-target": "dropdown" } }
    = link_to chat_profile_path, class: "sidebar-user-menu-item" do
      %i.fa-solid.fa-gear
      %span= current_client_label(:profile_settings_label)
    - if current_user&.admin?
      = link_to admin_root_path, class: "sidebar-user-menu-item", target: "_blank", rel: "noopener" do
        %i.fa-solid.fa-screwdriver-wrench
        %span= current_client_label(:admin_label)
    - if current_user&.local?
      %button.sidebar-user-menu-item{ type: "button", data: { action: "click->dialog#open click->user-menu#close" } }
        %i.fa-solid.fa-key
        %span= current_client_label(:change_password_label)
    %button.sidebar-user-menu-item{ data: { action: "click->theme#toggle click->user-menu#close" }, type: "button" }
      %i.fa-solid.fa-circle-half-stroke
      %span= current_client_label(:theme_label)
    = link_to session_path, data: { turbo_method: :delete }, class: "sidebar-user-menu-item sidebar-user-menu-item--danger" do
      %i.fa-solid.fa-right-from-bracket
      %span= current_client_label(:sign_out_label)
  - if current_user&.local?
    %dialog.dialog{ data: { dialog_target: "dialog", action: "click->dialog#backdropClick" } }
      .dialog-content
        .dialog-header
          %h3.dialog-title= current_client_label(:change_password_dialog_title)
          %button.dialog-close{ type: "button", data: { action: "dialog#close" } }
            %i.fa-solid.fa-times
        .dialog-body
          = turbo_frame_tag :password_change_dialog, src: edit_password_change_path, loading: :lazy
- main_content = capture do
  = yield
- footer_content = capture do
  - if current_client&.dig(:footer).present?
    .chat-footer.text-center.text-xs.text-text-muted.py-2.lexxy-content
      = sanitize current_client[:footer]
%html{ class: initial_theme_root_class, data: initial_theme_root_data }
  %head
    = render "layouts/head", title: content_for(:title) || client_name, application_name: client_name

  %body{ data: { controller: "theme" } }
    = render "shared/chat/client_frame", { client_name:, brand_url: client_chat_brand_url, new_chat_url: client_chat_new_path, sidebar_list:, sidebar_footer:, sidebar_footer_options: { data: { controller: "user-menu dialog" } }, main_content:, footer_content: }

    = render "shared/toast"
