- form_action = @login_tenant.present? ? tenant_login_path(@login_tenant) : sessions_path

- content_for(:title, "Sign In — #{APP_NAME}")

= form_tag form_action, class: "auth-form" do
  .form-group
    %label.form-label{ for: "email" } Email
    %input.form-input#email{ type: "email", name: "email", value: params[:email], placeholder: "admin@localhost", autofocus: true, required: true }

  .form-group
    .flex.items-center.justify-between
      %label.form-label{ for: "password" } Password
      = link_to "Forgot password?", new_password_reset_path, class: "auth-link text-xs"
    %input.form-input#password{ type: "password", name: "password", placeholder: "Enter your password", required: true }

  %button.btn.btn-primary.w-full{ type: "submit" }
    %i.fa-solid.fa-right-to-bracket.mr-2
    Sign In

- if Connectors::Authentication.enabled_for_provider?("keycloak")
  .auth-divider
    %span or

  = form_tag "/auth/keycloak", method: :post, class: "auth-oauth", data: { turbo: false } do
    %button.btn.btn-keycloak.w-full{ type: "submit" }
      %i.fa-solid.fa-key.mr-2
      Sign in with Keycloak

- if Connectors::Authentication.enabled_for_provider?("google")
  .auth-divider
    %span or

  = form_tag "/auth/google", method: :post, class: "auth-oauth", data: { turbo: false } do
    %button.btn.btn-google.w-full{ type: "submit" }
      %i.fa-brands.fa-google.mr-2
      Sign in with Google
