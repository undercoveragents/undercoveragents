.card.mb-6
  .card-header
    %h3.text-sm.font-semibold.text-text-primary
      %i.fa-solid.fa-user-gear.mr-2.text-accent
      Account Menu Labels
  .card-body
    .form-grid
      .form-group
        = f.label :profile_settings_label, "Profile Link", class: "form-label"
        = f.text_field :profile_settings_label, class: "form-input"
      .form-group
        = f.label :admin_label, "Admin Link", class: "form-label"
        = f.text_field :admin_label, class: "form-input"
      .form-group
        = f.label :change_password_label, "Change Password Link", class: "form-label"
        = f.text_field :change_password_label, class: "form-input"
      .form-group
        = f.label :change_password_dialog_title, "Change Password Dialog Title", class: "form-label"
        = f.text_field :change_password_dialog_title, class: "form-input"
      .form-group
        = f.label :theme_label, "Theme Toggle", class: "form-label"
        = f.text_field :theme_label, class: "form-input"
      .form-group
        = f.label :sign_out_label, "Sign Out Link", class: "form-label"
        = f.text_field :sign_out_label, class: "form-input"
