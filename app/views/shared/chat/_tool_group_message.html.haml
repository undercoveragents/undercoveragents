- tool_group_locals = { group_title:, items:, status: }
- action_message = local_assigns.fetch(:action_message, nil)
- action_copy_text = local_assigns.fetch(:action_copy_text, nil)
%article.shared-chat__message.shared-chat__message--assistant.shared-chat__message--stable.shared-chat__message--tool-group
  .shared-chat__assistant-panel
    .shared-chat__tool-calls
      = render partial: "shared/chat/tool_call_group", locals: tool_group_locals
    = render "shared/chat/message_actions", message: action_message, chat: local_assigns[:chat], component: local_assigns[:component], copy_text: action_copy_text if action_message.present? && local_assigns[:component]&.message_actions_for?(action_message)
